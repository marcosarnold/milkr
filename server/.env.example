# Milkr Server — environment variables
# Copy to .env and fill in values. Never commit .env.

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Firecrawl (https://firecrawl.dev — free tier: 1000 credits/month)
FIRECRAWL_API_KEY=fc-...

# Plaid (https://dashboard.plaid.com — free sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Lithic (https://lithic.com — free sandbox)
LITHIC_API_KEY=
LITHIC_ENV=sandbox

# Database
# Local dev: leave blank (uses SQLite at milkr.db)
# Production on Railway: set to your PostgreSQL URL
DATABASE_URL=

# CORS — comma-separated list of allowed origins
# Local dev: leave blank (allows all origins)
# Production: set to your extension's chrome-extension://ID origin
ALLOWED_ORIGINS=

# Railway auto-sets PORT — do not set manually in production
PORT=8000
